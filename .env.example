# =============================================================================
# phone-directory — environment variable reference
#
# Copy this file to .env (and optionally .env.local for local overrides).
# Only the variables under "User-Configurable" are intended to be set here.
# The remaining categories are documented for awareness; they are set
# automatically by the toolchain, CI, or OS — do not override them in .env
# unless you know what you are doing.
#
# Full documentation: docs/ENVIRONMENT.md
# =============================================================================

# -----------------------------------------------------------------------------
# User-Configurable
# Variables a developer may set locally to control development behaviour.
# -----------------------------------------------------------------------------

# Open Chromium DevTools automatically on startup.
# Truthy values: 1, true  |  Falsy: 0, false (or unset)
# The dev launcher (scripts/run-electron-dev.mjs) defaults this to 1 when unset.
ELECTRON_OPEN_DEVTOOLS=0

# -----------------------------------------------------------------------------
# Release / Portable  (set by the USB release launcher — not for local .env)
# -----------------------------------------------------------------------------

# Enable portable mode (data stored next to the executable, not in OS profile).
# ELECTRON_PORTABLE=1

# Absolute path to the portable root directory (required when ELECTRON_PORTABLE=1).
# ELECTRON_PORTABLE_ROOT_PATH=/path/to/portable-root

# -----------------------------------------------------------------------------
# Internal Runtime  (set by toolchain / OS — do not set manually)
# -----------------------------------------------------------------------------

# Vite dev-server URL loaded by the renderer in E2E mode.
# ELECTRON_RENDERER_URL=http://localhost:5173

# Override Electron's userData directory (only honoured when ELECTRON_E2E=1).
# ELECTRON_USER_DATA_PATH=/path/to/isolated-profile

# Set automatically by Vitest — used internally to skip fs-heavy code paths.
# VITEST=true

# Set automatically by the AppImage runtime on Linux.
# APPIMAGE=/path/to/app.AppImage

# Set automatically by CI providers (GitHub Actions, etc.).
# CI=true

# -----------------------------------------------------------------------------
# E2E-Only  (injected by Playwright test harness — never set in .env)
# -----------------------------------------------------------------------------

# Enables E2E mode in the main process (file-dialog interception, URL override).
# ELECTRON_E2E=1

# JSON array of paths returned by intercepted open-file dialogs.
# E2E_OPEN_DIALOG_PATHS=["/path/to/fixture.csv"]

# JSON array of paths returned by intercepted save-file dialogs.
# E2E_SAVE_DIALOG_PATHS=["/path/to/output.csv"]
